#!/usr/bin/env python3
# -*- coding: utf-8 -*-

import math
import argparse
import csv
import json
import os
import sys
import time
from datetime import datetime, timezone
import random
import statistics
import tempfile

try:
    import matplotlib.pyplot as plt
    import numpy as np
except Exception:
    plt = None
    np = None

DEFAULT_DURATION = 60
DEFAULT_INTERVAL = 1
RESULTS_DIR = "results"

# -------------------------
# Utilidades
# -------------------------
def iso_now_utc():
    return datetime.now(timezone.utc).strftime("%Y-%m-%dT%H:%M:%SZ")


def ensure_results_dir():
    os.makedirs(RESULTS_DIR, exist_ok=True)


def safe_write_atomic(path, text, mode="w", encoding="utf-8"):
    dirpath = os.path.dirname(path) or "."
    fd, tmp_path = tempfile.mkstemp(dir=dirpath, prefix=".tmp_")
    try:
        with os.fdopen(fd, mode, encoding=encoding) as f:
            f.write(text)
        os.replace(tmp_path, path)
    except Exception:
        try:
            os.remove(tmp_path)
        except Exception:
            pass
        raise

# -------------------------
# 🔹 Mejora A: Filtrado + Calibración
# -------------------------
def moving_average(values, window_size=5):
    result = []
    for i in range(len(values)):
        window = values[max(0, i - window_size + 1):i + 1]
        clean = [v for v in window if isinstance(v, (int, float)) and not (isinstance(v, float) and v != v)]
        if clean:
            result.append(round(sum(clean) / len(clean), 3))
        else:
            result.append(float("nan"))
    return result


def calibrate_offset(values, n_samples=10):
    initial = values[:n_samples]
    clean = [v for v in initial if isinstance(v, (int, float)) and not (isinstance(v, float) and v != v)]
    if not clean:
        return 0
    return statistics.mean(clean)

# -------------------------
# Simulación
# -------------------------
def simulate_reading(t_seconds):
    temp_base = 22.0 + 0.01 * t_seconds
    temp_noise = random.gauss(0, 0.2)
    temp = temp_base + temp_noise

    ldr_base = 400 + 50 * (0.5 * (1 + math.sin(t_seconds / 5.0)))
    ldr_noise = random.gauss(0, 10)
    if random.random() < 0.02:
        ldr_noise += random.uniform(100, 300)
    ldr = int(max(0, min(1023, ldr_base + ldr_noise)))

    return round(temp, 2), ldr

# -------------------------
# Adquisición
# -------------------------
def acquire_data(duration_seconds, sample_interval_s):
    readings = []
    start_time = time.time()
    elapsed = 0.0

    while elapsed < duration_seconds:
        t_now = iso_now_utc()
        temp, ldr = simulate_reading(elapsed)
        readings.append((t_now, temp, ldr))

        time.sleep(sample_interval_s)
        elapsed = time.time() - start_time

    return readings

# -------------------------
# CSV (MODIFICADO)
# -------------------------
def save_csv(readings, temps_filt, ldrs_filt, path):
    header = ["timestamp", "temp_raw", "ldr_raw", "temp_filt", "ldr_filt"]
    lines = [",".join(header) + "\n"]

    for i, (ts, temp, ldr) in enumerate(readings):
        tf = temps_filt[i]
        lf = ldrs_filt[i]

        lines.append(f"{ts},{temp},{ldr},{tf},{lf}\n")

    safe_write_atomic(path, "".join(lines))
    print(f"[INFO] CSV guardado en {path}")

# -------------------------
# Gráfica (actualizada)
# -------------------------
def plot_readings(readings, temps_filt, ldrs_filt, plot_path):
    if plt is None or np is None:
        print("[WARN] Sin matplotlib")
        return

    timestamps = [datetime.strptime(ts, "%Y-%m-%dT%H:%M:%SZ") for ts, _, _ in readings]
    x = np.array([t.timestamp() for t in timestamps])
    x = x - x[0]

    temps = [t for _, t, _ in readings]
    ldrs = [l for _, _, l in readings]

    fig, ax1 = plt.subplots()

    ax1.plot(x, temps, label="Temp Raw")
    ax1.plot(x, temps_filt, linestyle="--", label="Temp Filt")

    ax2 = ax1.twinx()
    ax2.plot(x, ldrs, label="LDR Raw")
    ax2.plot(x, ldrs_filt, linestyle="--", label="LDR Filt")

    fig.legend()
    plt.savefig(plot_path)
    plt.close()

# -------------------------
# MAIN (MODIFICADO)
# -------------------------
def main():
    parser = argparse.ArgumentParser()
    parser.add_argument("--duration", type=int, default=DEFAULT_DURATION)
    parser.add_argument("--interval", type=float, default=DEFAULT_INTERVAL)
    args = parser.parse_args()

    ensure_results_dir()

    readings = acquire_data(args.duration, args.interval)

    temps = [t for _, t, _ in readings]
    ldrs = [l for _, _, l in readings]

    # 🔹 Calibración
    offset_temp = calibrate_offset(temps)
    offset_ldr = calibrate_offset(ldrs)

    temps_cal = [t - offset_temp for t in temps]
    ldrs_cal = [l - offset_ldr for l in ldrs]

    # 🔹 Filtrado
    temps_filt = moving_average(temps_cal)
    ldrs_filt = moving_average(ldrs_cal)

    # Guardar CSV
    csv_path = os.path.join(RESULTS_DIR, "raw_readings.csv")
    save_csv(readings, temps_filt, ldrs_filt, csv_path)

    # Gráfica
    plot_path = os.path.join(RESULTS_DIR, "plot.png")
    plot_readings(readings, temps_filt, ldrs_filt, plot_path)

    print("[INFO] Proceso completo")

if __name__ == "__main__":
    main()
